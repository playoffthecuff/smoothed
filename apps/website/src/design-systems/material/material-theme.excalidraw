    {
      "id": "aSPjJ-oG4c4GRk5KOH1Lb",
      "type": "text",
      "x": 1906.5828316901052,
      "y": 892.9601361325252,
      "width": 1037.7704720202212,
      "height": 216,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2Z",
      "roundness": null,
      "seed": 561619830,
      "version": 2125,
      "versionNonce": 1006473602,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769685570214,
      "link": null,
      "locked": false,
      "text": "логика размеров линейна на логарифмической шкале и выражается уравнением\nsize = 2^(1/4 * value) * var(--spacing-size), где value - значение из утилитного класса а var(--spacing-size)\nлинейный коэффиент масштабирования из настроек темы (по умолчанию опускается, тк равен 1). Значение\nразмера получается в единицах 1/16rem (1 пиксель если пользователь не изменял настройки браузера).\nПри увеличении размера на 4, результат удваивается. Изменение размера на единицу, корректирует\nвеличину в ~1.189 (корень четвертой степени из двух раз), то есть примерно на 20%. Для тонкой\nподстройки можно указать промежуточное значение, например 3.5, 10.5 и тд., что даст корректировку в\nкорень восьмой степени из двух раз, то есть примерно 10%.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "логика размеров линейна на логарифмической шкале и выражается уравнением\nsize = 2^(1/4 * value) * var(--spacing-size), где value - значение из утилитного класса а var(--spacing-size) линейный коэффиент масштабирования из настроек темы (по умолчанию опускается, тк равен 1). Значение размера получается в единицах 1/16rem (1 пиксель если пользователь не изменял настройки браузера). При увеличении размера на 4, результат удваивается. Изменение размера на единицу, корректирует величину в ~1.189 (корень четвертой степени из двух раз), то есть примерно на 20%. Для тонкой подстройки можно указать промежуточное значение, например 3.5, 10.5 и тд., что даст корректировку в корень восьмой степени из двух раз, то есть примерно 10%.",
      "autoResize": false,
      "lineHeight": 1.35
    },
