    {
      "id": "HYdfxvUnRH6bkBva7OFzh",
      "type": "text",
      "x": 3440.030439942298,
      "y": 2558.4005322800085,
      "width": 459.8996887207031,
      "height": 27,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
