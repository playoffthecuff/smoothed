    {
      "id": "zIwOaFR-jGDr0tb9ERJ4r",
      "type": "text",
      "x": 3088.2406737247593,
      "y": 1500.143579104832,
      "width": 369.53961181640625,
      "height": 27,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4h",
      "roundness": null,
      "seed": 1795158402,
      "version": 1401,
      "versionNonce": 1833726819,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769866027277,
      "link": null,
      "locked": false,
      "text": "v = k*N + (2N - 2*k*N) * lightness / 1000",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "v = k*N + (2N - 2*k*N) * lightness / 1000",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "QiW9cyc44-z8-CcmqROGN",
      "type": "text",
      "x": 3514.7513297027517,
      "y": 1961.4497031899896,
      "width": 88.45988464355469,
      "height": 27,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4i",
      "roundness": null,
      "seed": 501101214,
      "version": 1390,
      "versionNonce": 1187909379,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769866027277,
      "link": null,
      "locked": false,
      "text": "N * (2 - k)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "N * (2 - k)",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "o7-BIoNqXmXJPjXGV0Jps",
      "type": "text",
      "x": 4204.0847647613455,
      "y": 1969.449825260302,
      "width": 88.45988464355469,
      "height": 27,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4j",
      "roundness": null,
      "seed": 500983938,
      "version": 1469,
      "versionNonce": 551237283,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769866027277,
      "link": null,
      "locked": false,
      "text": "N * (2 - k)",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "N * (2 - k)",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "4gA74lll5xsAJlfZldE-q",
      "type": "text",
      "x": 3073.0120975407162,
      "y": 1940.2487744032878,
      "width": 400.57952880859375,
      "height": 27,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4n",
      "roundness": null,
      "seed": 1165928770,
      "version": 799,
      "versionNonce": 2049075779,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769866027277,
      "link": null,
      "locked": false,
      "text": "v = kN - (2N * (k - 1) * (1 - lightness / 1000))",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "v = kN - (2N * (k - 1) * (1 - lightness / 1000))",
      "autoResize": true,
      "lineHeight": 1.35
    },
