    {
      "id": "VZAOfCvdUptd4k7aHTDkK",
      "type": "text",
      "x": 3183.3919500766056,
      "y": 3072.918169860882,
      "width": 1108.4190673828125,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5X",
      "roundness": null,
      "seed": 844491324,
      "version": 2915,
      "versionNonce": 2007249123,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1769866027277,
      "link": null,
      "locked": false,
      "text": "Промежуточное решение - отсекать по APCA contrast === 0 подходит для большинства кейсов кроме специфичных\nкогда доля цвета с высокой перцептивной чувствительностью большая:\napcaContrast(\"oklch(0.75 0.3125 142.4953)\", \"oklch(0.8664 0.3609 142.4953)\") => 18.6\napcaContrast(\"oklch(0.75 0.3125 142.4953)\", \"oklch(0.8664 0.1258 322.5)\") => 9\n",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Промежуточное решение - отсекать по APCA contrast === 0 подходит для большинства кейсов кроме специфичных\nкогда доля цвета с высокой перцептивной чувствительностью большая:\napcaContrast(\"oklch(0.75 0.3125 142.4953)\", \"oklch(0.8664 0.3609 142.4953)\") => 18.6\napcaContrast(\"oklch(0.75 0.3125 142.4953)\", \"oklch(0.8664 0.1258 322.5)\") => 9\n",
      "autoResize": true,
      "lineHeight": 1.35
    },
