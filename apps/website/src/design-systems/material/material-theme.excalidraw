    {
      "id": "0VjvvqY3rh6hhhVY40u_x",
      "type": "text",
      "x": 3710.7251867709415,
      "y": 2889.695935770713,
      "width": 532.4396362304688,
      "height": 162,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
